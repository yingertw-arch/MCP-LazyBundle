{
  "mcpServers": {
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "bearer_token_env_var": "GITHUB_PAT_TOKEN"
    },
    "firebase": {
      "command": "npx.cmd",
      "args": ["-y", "firebase-tools@latest", "mcp"]
    },
    "obsidian": {
      "url": "http://127.0.0.1:27123/mcp/",
      "bearer_token_env_var": "OBSIDIAN_API_KEY"
    },
    "notebooklm": {
      "command": "npx.cmd",
      "args": ["-y", "notebooklm-mcp@latest"]
    }
  }
}
